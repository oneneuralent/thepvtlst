{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "AGENT_API_URL",
        "AGENT_API_SECRET",
        "OPENROUTER_API_KEY",
        "OPENROUTER_MODEL",
        "TAVILY_API_KEY",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_REDIRECT_URI",
        "AUTH_MODE",
        "DEV_USER_ID",
        "DEV_USER_EMAIL",
        "TOKEN_ENCRYPTION_KEY",
        "NVIDIA_NIM_API_KEY",
        "CLERK_SECRET_KEY"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "typecheck": {}
  }
}
